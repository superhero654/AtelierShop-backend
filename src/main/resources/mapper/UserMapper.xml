<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.su.ateliershop.mapper.UserMapper">
    <select id="findById" resultType="com.su.ateliershop.entity.User">
        SELECT * FROM user WHERE id = #{id}
    </select>
    <select id="findByUsername" resultType="com.su.ateliershop.entity.User">
        SELECT * FROM user WHERE username = #{username}
    </select>
    <select id="findByEmail" resultType="com.su.ateliershop.entity.User">
        SELECT * FROM user WHERE email = #{email}
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user (username, email, password, nickname, phone, address)
        VALUES (#{username}, #{email}, #{password}, #{nickname}, #{phone}, #{address})
    </insert>
    <update id="update">
        UPDATE user SET
            nickname = #{nickname},
            phone = #{phone},
            address = #{address},
            email = #{email}
        WHERE id = #{id}
    </update>
</mapper>
