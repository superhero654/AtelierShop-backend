<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.su.ateliershop.mapper.AdminMapper">
    <select id="findById" resultType="com.su.ateliershop.entity.Admin">
        SELECT * FROM admin WHERE id = #{id}
    </select>
    <select id="findByUsername" resultType="com.su.ateliershop.entity.Admin">
        SELECT * FROM admin WHERE username = #{username}
    </select>
    <select id="findAll" resultType="com.su.ateliershop.entity.Admin">
        SELECT * FROM admin ORDER BY id
    </select>
</mapper>
